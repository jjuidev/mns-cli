{
  "name": "@jjuidev/mns-cli",
  "version": "0.0.1",
  "description": "Meeting Notes - Video meeting analyzer CLI tool",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "bin": {
    "mns": "./dist/cli/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run src/build.ts",
    "changeset": "changeset",
    "clean": "rimraf dist",
    "dev": "bun run --watch src/cli.ts",
    "format": "eslint --fix \"src/**/*.{js,ts,jsx,tsx}\" && prettier --write \"src/**/*.{js,ts,jsx,tsx}\"",
    "prepare": "husky",
    "release": "bun run clean && bun run build && changeset publish",
    "version": "changeset version"
  },
  "types": "./dist/types/index.d.ts",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.47.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "defu": "^6.1.4",
    "execa": "^9.6.1",
    "figlet": "^1.10.0",
    "fluent-ffmpeg": "^2.1.3",
    "globby": "^16.1.0",
    "nypm": "^0.6.5",
    "pathe": "^2.0.3",
    "strip-json-comments": "^5.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.0.0",
    "@jjuidev/jss-devtools": "^0.3.1",
    "@types/bun": "^1.3.9",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-autofix": "^2.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "keywords": [
    "ai",
    "cli",
    "gemini",
    "meeting-notes",
    "transcription",
    "video-analyzer"
  ],
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "package.json": [
      "bunx prettier-package-json --write"
    ]
  }
}
